# Copy to .env.local and fill in real values (never commit .env.local):
#   cp .env.example .env.local
#
# When adding new features, update BOTH this file and .env.local.

# ─── AI (hosted SaaS — users do NOT need their own key) ───
GEMINI_API_KEY=your_gemini_api_key_here

# Public URL (OAuth redirects)
# Production: https://growth.biblefunland.com/
APP_URL=http://localhost:3000/
# VITE_APP_URL=https://growth.biblefunland.com

# ─── Local dev API token (optional when Supabase cloud auth is enabled) ───
CMO_API_TOKEN=generate_a_long_random_token_here
VITE_CMO_API_TOKEN=generate_a_long_random_token_here

# ─── Supabase (cloud accounts + workspace sync) ───
# Create project at https://supabase.com → run supabase/schema.sql in SQL Editor
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Google OAuth (Search Console + GA4) ───
# https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/integrations/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Product mode ───
# Set to true to show studio bundles, product switcher, and cross-app upsells
# VITE_SHOW_GROWTH_STACK=false

# Server port (Render/Heroku set PORT automatically)
# PORT=3000

# ─── Owner plan grant (server-only — no Stripe) ───
# Comma-separated emails that always receive CADENCE_OWNER_PLAN on the server.
# Set on Render only; never commit real addresses.
# CADENCE_OWNER_EMAILS=you@example.com
# CADENCE_OWNER_PLAN=team
# API_RATE_LIMIT_MAX=40
# ALLOW_LOCALHOST_WITHOUT_TOKEN=true

# Observability (optional)
# SENTRY_DSN=https://your-sentry-dsn

# ─── Growth stack partner APIs (Phase 2) ───
# CITEPILOT_API_URL=https://getcitepilot.com
# CITEPILOT_PARTNER_API_KEY=
# AEGIS_API_URL=https://aegis-loop.com
# AEGIS_PARTNER_API_KEY=
# PULSE_API_URL=https://pulse-5o1m.onrender.com
# VITE_PULSE_URL=https://pulse-5o1m.onrender.com
# Shared master read key (must match Pulse PULSE_READ_KEY) OR
# PULSE_API_KEY=
# Per-site keys JSON (must match Pulse PULSE_SITE_KEYS) — preferred once multi-tenant
# PULSE_SITE_KEYS={"biblefunlandstudios-com":"psk_…"}
# Partner secret — same on Cadence + Pulse; site keys + SSO + Cadence-loop “drove”
# Cadence: GET /api/partner/pulse/drove · POST Pulse /api/partner/sites|sso|drove
# Run supabase/schema-v7-pulse-collect.sql for pulse_collect_key on claims
# PULSE_PARTNER_SECRET=
# Optional global collect key (embedded in snippet when set on Cadence server)
# PULSE_COLLECT_KEY=
# Run supabase/schema-v5-pulse-claims.sql for claim → auto-key flow
# Run supabase/schema-v6-growth-stack-keys.sql for cloud-synced sister product keys

# ─── Stripe (billing: Pro / Team + studio bundles) ───
# https://dashboard.stripe.com — see docs/STRIPE_BUNDLES.md
# Webhook endpoint: POST /api/billing/webhook (use Stripe CLI locally)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_BUNDLE_GROWTH_MONTHLY=
STRIPE_PRICE_BUNDLE_SOCIAL_MONTHLY=
STRIPE_PRICE_BUNDLE_DEVSEC_MONTHLY=
STRIPE_PRICE_BUNDLE_STUDIO_MONTHLY=

# ─── Studio billing fan-out (Phase 4) ───
# Shared secret with sister products; same value on each app
STUDIO_BILLING_FANOUT_SECRET=
KERYGMA_STUDIO_BILLING_URL=
CITEPILOT_STUDIO_BILLING_URL=
AEGIS_STUDIO_BILLING_URL=

# ─── Studio Ops (internal mission control) ───
# Same STUDIO_OPS_WEBHOOK_SECRET as studio-ops/.env.local
STUDIO_OPS_URL=http://localhost:3010
STUDIO_OPS_WEBHOOK_SECRET=
